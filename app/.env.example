# Human-AgentOS runtime mode.
# Allowed future values: local_demo | full_stack
VITE_APP_RUNTIME_MODE=local_demo

# Browser-visible Supabase configuration.
# These values are exposed by Vite and must never contain server secrets.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace_with_publishable_key

# Server-only Supabase configuration.
# Never expose these values through VITE_* variables.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=replace_with_server_only_secret

# Single approved Admin identity.
ADMIN_USER_ID=00000000-0000-0000-0000-000000000000

# Server-only OpenAI configuration.
OPENAI_API_KEY=replace_with_server_only_key
OPENAI_MODEL=unresolved_until_phase_22e

# Server-only execution controls.
# Exact values remain unresolved until Phase 22G.
AGENT_RUN_STALE_AFTER_SECONDS=unresolved_until_phase_22g
AGENT_RUN_MAX_PER_TASK=unresolved_until_phase_22g
AGENT_RUN_MAX_PER_OWNER=unresolved_until_phase_22g
AGENT_RUN_TIMEOUT_MS=unresolved_until_phase_22g
