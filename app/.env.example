# SymbiontOS runtime mode. Keep `local_demo` for judge-safe previews.
VITE_APP_RUNTIME_MODE=local_demo

# Browser-visible Supabase configuration. Never place server secrets here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace_with_publishable_key

# Vercel server-only configuration.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace_with_publishable_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
ADMIN_USER_ID=00000000-0000-0000-0000-000000000000
OPENAI_API_KEY=replace_with_server_only_key
OPENAI_MODEL=gpt-4.1-mini

# Phase 22 production controls.
AGENT_DAILY_QUOTA=25
AGENT_COOLDOWN_SECONDS=10
AGENT_TIMEOUT_MS=60000
ATTACHMENT_MAX_FILES=5
ATTACHMENT_MAX_BYTES=1048576
ATTACHMENT_MAX_EXTRACTED_CHARACTERS=100000
